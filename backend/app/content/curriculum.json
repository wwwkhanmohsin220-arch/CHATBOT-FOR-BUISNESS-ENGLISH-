          "concept_tags": [
            "polite_disagreement",
            "meeting_vocabulary"
          ],
          "key_vocabulary": [
            "I hear your concern",
            "Alternative approach",
            "Pushback",
            "Agenda"
          ],
          "grammar_points": [
            "Softeners and hedging: 'I appreciate your point, however...'"
          ],
          "example_phrases": [
            "I appreciate your concern about the budget; however, let's explore an alternative approach."
          ]
        },
        {
          "slot_key": "u1l3",
          "position": 3,
          "objectives": [
            "Draft structured professional emails",
            "Choose appropriate level of formality for follow-ups"
          ],
          "concept_tags": [
            "email_structure",
            "tone_formality"
          ],
          "key_vocabulary": [
            "Please find attached",
            "Further clarification",
            "Best regards",
            "Following up on"
          ],
          "grammar_points": [
            "Formal email greetings and sign-offs"
          ],
          "example_phrases": [
            "I am following up on our meeting from yesterday. Please find the proposal attached."
          ]
        }
      ]
    },
    {
      "id": 2,
